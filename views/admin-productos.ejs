<%- include('partials/header') %>

<main class="container">
    <% if (alerta) { %>
        <div class="alert-banner">
            <%= alerta %>
        </div>
    <% } %>

    <div class="admin-page-header">
        <h2>📦 Gestión del Catálogo de Productos</h2>
        <div class="nav-links">
            <a href="/admin" class="back-link">📋 Ver Pedidos</a>
            <a href="/logout" class="btn-delete">Cerrar Sesión</a>
        </div>
    </div>

    <div class="custom-layout-grid">
        <section class="form-custom-column">
            <h3 class="form-title">✨ Añadir Nuevo Producto</h3>
            <p class="form-subtitle">Completa los datos para publicarlo en la tienda virtual.</p>

            <form action="/admin/productos/agregar" method="POST" enctype="multipart/form-data" class="login-form">
                <div class="form-group">
                    <label for="title" class="form-label">Nombre del producto</label>
                    <input type="text" id="title" name="title" required class="form-input" placeholder="Ej: Jirafa Melcocha Tejida">
                </div>

                <div class="form-group">
                    <label for="base_price" class="form-label">Precio Base ($)</label>
                    <input type="number" id="base_price" name="base_price" required class="form-input" placeholder="Ej: 45000">
                </div>

                <div class="form-group">
                    <label for="image_file" class="form-label">Foto del producto *</label>
                    <input type="file" id="image_file" name="image_file" accept="image/*" required class="form-input">
                </div>

                <div class="form-group">
                    <label for="description" class="form-label">Descripción o Detalles</label>
                    <textarea id="description" name="description" class="form-input form-textarea" placeholder="Especifica el tamaño, materiales..."></textarea>
                </div>

                <button type="submit" class="btn-order btn-block">🚀 Publicar en la Tienda</button>
            </form>
        </section>

        <section class="product-preview-column">
            <div class="admin-table-container">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Producto</th>
                            <th>Precio Base</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (productos.length === 0) { %>
                            <tr>
                                <td colspan="4" class="hero-text">
                                    El catálogo está vacío. ¡Agrega tu primer producto!
                                </td>
                            </tr>
                        <% } %>
                        <% productos.forEach(prod => { %>
                            <tr>
                                <td>
                                    <img src="<%= prod.image_url %>" alt="<%= prod.title %>" class="table-img">
                                </td>
                                <td>
                                    <span class="td-bold"><%= prod.title %></span>
                                    <p class="form-subtitle"><%= prod.description || 'Sin descripción' %></p>
                                </td>
                                <td class="td-price">$<%= prod.base_price %></td>
                                <td>
                                    <div class="table-actions">
                                        <a href="/admin/productos/editar/<%= prod.id %>" class="btn-customize">Editar</a>
                                        
                                    <form action="/admin/productos/eliminar" method="POST" onsubmit="return confirm('¿Seguro que quieres eliminar este producto del catálogo?');">
                                        <input type="hidden" name="producto_id" value="<%= prod.id %>">
                                        <button type="submit" class="btn-danger">Eliminar</button>
                                    </form>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</main>
<%- include('partials/footer') %>
</body>
</html>