<%- include('partials/header') %>

<main class="login-main-container">
    <div class="login-card">
        <h2 class="login-title">🔐 Acceso al Panel</h2>
        <p class="login-subtitle">Ingresa tus credenciales para administrar los pedidos.</p>

        <% if (error) { %>
            <p class="login-error-message"><%= error %></p>
        <% } %>

        <form action="/login" method="POST" class="login-form">
            <div class="form-group">
                <label for="username" class="form-label">Usuario</label>
                <input type="text" id="username" name="username" required class="form-input" placeholder="Ej: admin">
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" id="password" name="password" required class="form-input" placeholder="••••••••">
            </div>

            <button type="submit" class="btn-order btn-block">Iniciar Sesión</button>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
</body>
</html>