<%- include('partials/header') %>

<main class="container custom-order-page">
    <div class="custom-order-container">
        <h2 class="custom-order-title">✨ Cuéntanos tu idea</h2>
        <p class="custom-order-subtitle">
            Describe el amigurumi que imaginas. Te contactaremos por el medio que elijas con la cotización oficial.
        </p>

        <form action="/pedido-personalizado" method="POST" enctype="multipart/form-data" class="custom-order-form">
            
            <div class="form-group">
                <label class="form-label">Tu Name / Nombre:</label>
                <input type="text" name="nombre_cliente" required class="form-input">
            </div>

            <div class="form-group">
                <label class="form-label">Teléfono / WhatsApp de Contacto:</label>
                <input type="text" name="telefono_cliente" required placeholder="Ej: 3121234567" class="form-input">
            </div>

            <div class="form-group">
                <label class="form-label">Correo Electrónico (Gmail):</label>
                <input type="email" name="correo_cliente" required placeholder="ejemplo@gmail.com" class="form-input">
            </div>

            <div class="form-group">
                <label class="form-label">¿Cómo prefieres que te contactemos?</label>
                <select name="metodo_contacto" class="form-select">
                    <option value="WhatsApp">🟢 WhatsApp</option>
                    <option value="Gmail">✉️ Correo Electrónico (Gmail)</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">¿Cómo te lo imaginas? (Detalles, colores, tamaño):</label>
                <textarea name="custom_notes" rows="4" required placeholder="Ej: Quiero un perrito de unos 20cm con un gorrito verde..." class="form-textarea"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">📸 Imagen de Referencia (Obligatoria):</label>
                <input type="file" name="reference_image" accept="image/*" required class="form-file">
            </div>

            <button type="submit" class="btn-submit-custom">
                🚀 Enviar Solicitud de Cotización
            </button>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
</body>
</html>